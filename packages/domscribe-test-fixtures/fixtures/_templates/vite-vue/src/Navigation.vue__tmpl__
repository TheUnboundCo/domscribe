<script setup lang="ts">
/**
 * Navigation Component
 * Sidebar navigation for Vue test fixture showcase
 */

interface NavItem {
  id: string;
  label: string;
  section: string;
}

const navItems: NavItem[] = [
<%- navItems %>
];

defineProps<{
  activeItem: string;
}>();

const emit = defineEmits<{
  navigate: [id: string];
}>();

// Group items by section
const sections = [...new Set(navItems.map((item) => item.section))];

function getItemsForSection(section: string): NavItem[] {
  return navItems.filter((item) => item.section === section);
}

function handleNavigate(id: string) {
  emit('navigate', id);
}
</script>

<template>
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">
        <div class="sidebar-logo-icon">D</div>
        <span class="sidebar-logo-text">Domscribe Tests</span>
      </div>
    </div>

    <nav class="sidebar-nav">
      <div
        v-for="section in sections"
        :key="section"
        class="sidebar-section"
      >
        <div class="sidebar-section-title">{{ section }}</div>
        <div
          v-for="item in getItemsForSection(section)"
          :key="item.id"
          :data-page-id="item.id"
          :class="['sidebar-link', { active: activeItem === item.id }]"
          @click="handleNavigate(item.id)"
        >
          {{ item.label }}
        </div>
      </div>
    </nav>
  </div>
</template>

<style scoped>
/* Styles are in index.css */
</style>
