{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "vite/client",
      "vitest",
      "node"
    ],
    "tsBuildInfoFile": "../../dist/packages/domscribe-relay/tsconfig.spec.tsbuildinfo",
    "module": "nodenext",
    "moduleResolution": "nodenext"
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/**/*.d.ts"
  ],
  "references": [{ "path": "./tsconfig.lib.json" }]
}
